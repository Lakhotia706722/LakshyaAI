# ─────────────────────────────────────────────────────────────
# Lakshya AI — Environment Variables
# Phase 6 (multi-tenancy + security hardening)
# ─────────────────────────────────────────────────────────────
#
# Secrets management (recommended for production):
#   Use Doppler (https://doppler.com) — free tier works for solo devs.
#   Install: `pip install doppler-env` or use the Doppler CLI.
#   Run: `doppler run -- uvicorn app.main:app`
#   This file is only for local development. Never commit real secrets.
#
# Generate a secure JWT_SECRET with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Environment ───────────────────────────────────────────────
APP_ENV=development
# Set to "production" on Railway/Render — enables HSTS, disables create_all, enforces JWT_SECRET strength

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./lakshya.db
# For production: postgresql://user:password@host:5432/lakshya_ai
# Railway auto-sets DATABASE_URL when you add a Postgres plugin.
# postgres:// URIs are automatically rewritten to postgresql:// by the app.

# ── JWT / Auth ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS!!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (SMTP) ──────────────────────────────────────────────
# Leave blank for local dev — verification links are printed to the console.
# For production, use SendGrid, Resend, or AWS SES SMTP credentials.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com
FRONTEND_URL=http://localhost:5173
REQUIRE_EMAIL_VERIFICATION=false

# ── Redis ─────────────────────────────────────────────────────
# Required for production-grade rate limiting.
# Railway: add the Redis plugin, it auto-sets REDIS_URL.
# Local dev: leave blank to use in-memory fallback (single process only).
REDIS_URL=redis://localhost:6379/0

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
# S3 / Cloudflare R2 (leave blank to use local filesystem in dev)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
# For Cloudflare R2, set AWS_REGION=auto and override the endpoint in code.

# ── AI APIs ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here-optional

# ── Google OAuth (stub — disabled by default) ─────────────────
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── CORS ──────────────────────────────────────────────────────
# FRONTEND_URL above is the primary allowed origin.
# Add extra origins here (comma-separated) for Vercel preview URLs during development.
ALLOWED_EXTRA_ORIGINS=

# ── Rate Limiting ─────────────────────────────────────────────
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
ORG_RATE_LIMIT_REQUESTS=1000
ORG_RATE_LIMIT_WINDOW_SECONDS=3600
